{
  "$defs": {
    "AgentRunStatus": {
      "additionalProperties": false,
      "properties": {
        "completed_task_count": {
          "default": 0,
          "title": "Completed Task Count",
          "type": "integer"
        },
        "error_task_count": {
          "default": 0,
          "title": "Error Task Count",
          "type": "integer"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Message"
        },
        "partial_task_count": {
          "default": 0,
          "title": "Partial Task Count",
          "type": "integer"
        },
        "status": {
          "enum": [
            "SUCCESS",
            "PARTIAL",
            "ERROR"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "status"
      ],
      "title": "AgentRunStatus",
      "type": "object"
    },
    "AtomicClaimDecision": {
      "additionalProperties": false,
      "properties": {
        "citation_ids": {
          "items": {
            "type": "string"
          },
          "title": "Citation Ids",
          "type": "array"
        },
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "claim_text": {
          "title": "Claim Text",
          "type": "string"
        },
        "logic_role": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Logic Role"
        },
        "missing_slots": {
          "items": {
            "type": "string"
          },
          "title": "Missing Slots",
          "type": "array"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "verdict": {
          "enum": [
            "SUPPORTED",
            "REFUTED",
            "CONFLICT",
            "INCONCLUSIVE"
          ],
          "title": "Verdict",
          "type": "string"
        }
      },
      "required": [
        "claim_id",
        "claim_text",
        "verdict",
        "reason"
      ],
      "title": "AtomicClaimDecision",
      "type": "object"
    },
    "CitationJudgment": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "directness": {
          "maximum": 1,
          "minimum": 0,
          "title": "Directness",
          "type": "number"
        },
        "quote_match_mode": {
          "enum": [
            "EXACT",
            "NORMALIZED",
            "SNIPPET",
            "STRUCTURED_ROW"
          ],
          "title": "Quote Match Mode",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "refuted_claim_ids": {
          "items": {
            "type": "string"
          },
          "title": "Refuted Claim Ids",
          "type": "array"
        },
        "scope_compatible": {
          "title": "Scope Compatible",
          "type": "boolean"
        },
        "scope_mismatch_reasons": {
          "items": {
            "type": "string"
          },
          "title": "Scope Mismatch Reasons",
          "type": "array"
        },
        "supported_claim_ids": {
          "items": {
            "type": "string"
          },
          "title": "Supported Claim Ids",
          "type": "array"
        }
      },
      "required": [
        "confidence",
        "directness",
        "reason",
        "scope_compatible",
        "quote_match_mode"
      ],
      "title": "CitationJudgment",
      "type": "object"
    },
    "CitationProvenance": {
      "additionalProperties": false,
      "properties": {
        "content_fingerprint": {
          "title": "Content Fingerprint",
          "type": "string"
        },
        "dataset_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dataset Id"
        },
        "published_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Published At"
        },
        "query_execution_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Query Execution Id"
        },
        "query_ids": {
          "items": {
            "type": "string"
          },
          "title": "Query Ids",
          "type": "array"
        },
        "retrieved_at": {
          "title": "Retrieved At",
          "type": "string"
        },
        "scenario_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scenario Key"
        },
        "source_evidence_fingerprint": {
          "title": "Source Evidence Fingerprint",
          "type": "string"
        },
        "tool_call_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Call Id"
        }
      },
      "required": [
        "retrieved_at",
        "content_fingerprint",
        "source_evidence_fingerprint"
      ],
      "title": "CitationProvenance",
      "type": "object"
    },
    "CitationRecord": {
      "additionalProperties": false,
      "properties": {
        "chunk_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Chunk Id"
        },
        "citation_id": {
          "title": "Citation Id",
          "type": "string"
        },
        "content": {
          "minLength": 1,
          "title": "Content",
          "type": "string"
        },
        "document_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Document Id"
        },
        "file_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File Id"
        },
        "judgment": {
          "$ref": "#/$defs/CitationJudgment"
        },
        "knowledge_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Knowledge Id"
        },
        "page": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "provenance": {
          "$ref": "#/$defs/CitationProvenance"
        },
        "relation": {
          "enum": [
            "SUPPORT",
            "REFUTE",
            "SUPPLEMENT"
          ],
          "title": "Relation",
          "type": "string"
        },
        "source_name": {
          "title": "Source Name",
          "type": "string"
        },
        "source_type": {
          "enum": [
            "WEB",
            "KNOWLEDGE_BASE",
            "STRUCTURED_DATA"
          ],
          "title": "Source Type",
          "type": "string"
        },
        "status": {
          "enum": [
            "ACCEPTED",
            "DEGRADED"
          ],
          "title": "Status",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "task_ids": {
          "items": {
            "type": "string"
          },
          "title": "Task Ids",
          "type": "array"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        }
      },
      "required": [
        "citation_id",
        "task_ids",
        "content",
        "summary",
        "source_type",
        "source_name",
        "relation",
        "status",
        "judgment",
        "provenance"
      ],
      "title": "CitationRecord",
      "type": "object"
    },
    "EvidenceGap": {
      "additionalProperties": false,
      "properties": {
        "gap_retrieval_triggered": {
          "default": false,
          "title": "Gap Retrieval Triggered",
          "type": "boolean"
        },
        "missing_slots": {
          "items": {
            "type": "string"
          },
          "title": "Missing Slots",
          "type": "array"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "resolved": {
          "default": false,
          "title": "Resolved",
          "type": "boolean"
        }
      },
      "required": [
        "reason"
      ],
      "title": "EvidenceGap",
      "type": "object"
    },
    "PublicWarning": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        },
        "task_ids": {
          "items": {
            "type": "string"
          },
          "title": "Task Ids",
          "type": "array"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "PublicWarning",
      "type": "object"
    },
    "TaskDecision": {
      "additionalProperties": false,
      "properties": {
        "atomic_claim_results": {
          "items": {
            "$ref": "#/$defs/AtomicClaimDecision"
          },
          "title": "Atomic Claim Results",
          "type": "array"
        },
        "citation_ids": {
          "items": {
            "type": "string"
          },
          "title": "Citation Ids",
          "type": "array"
        },
        "conclusion_summary": {
          "title": "Conclusion Summary",
          "type": "string"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence_gap": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceGap"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "hypothesis_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hypothesis Id"
        },
        "item_id": {
          "title": "Item Id",
          "type": "string"
        },
        "line_type": {
          "enum": [
            "forward",
            "reverse"
          ],
          "title": "Line Type",
          "type": "string"
        },
        "node_id": {
          "title": "Node Id",
          "type": "string"
        },
        "refuting_citation_ids": {
          "items": {
            "type": "string"
          },
          "title": "Refuting Citation Ids",
          "type": "array"
        },
        "run_status": {
          "enum": [
            "SUCCESS",
            "PARTIAL",
            "ERROR"
          ],
          "title": "Run Status",
          "type": "string"
        },
        "supplementary_citation_ids": {
          "items": {
            "type": "string"
          },
          "title": "Supplementary Citation Ids",
          "type": "array"
        },
        "supporting_citation_ids": {
          "items": {
            "type": "string"
          },
          "title": "Supporting Citation Ids",
          "type": "array"
        },
        "target_text": {
          "title": "Target Text",
          "type": "string"
        },
        "task_id": {
          "title": "Task Id",
          "type": "string"
        },
        "verdict": {
          "enum": [
            "SUPPORTED",
            "REFUTED",
            "CONFLICT",
            "INCONCLUSIVE"
          ],
          "title": "Verdict",
          "type": "string"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "task_id",
        "item_id",
        "node_id",
        "line_type",
        "target_text",
        "run_status",
        "verdict",
        "confidence",
        "conclusion_summary"
      ],
      "title": "TaskDecision",
      "type": "object"
    },
    "TraceReference": {
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Trace Id"
        },
        "trace_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Trace Url"
        }
      },
      "title": "TraceReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "citations": {
      "items": {
        "$ref": "#/$defs/CitationRecord"
      },
      "title": "Citations",
      "type": "array"
    },
    "document_id": {
      "title": "Document Id",
      "type": "string"
    },
    "paragraph_id": {
      "title": "Paragraph Id",
      "type": "string"
    },
    "request_id": {
      "title": "Request Id",
      "type": "string"
    },
    "results": {
      "items": {
        "$ref": "#/$defs/TaskDecision"
      },
      "title": "Results",
      "type": "array"
    },
    "run_status": {
      "$ref": "#/$defs/AgentRunStatus"
    },
    "schema_version": {
      "const": "search-agent-output/v1",
      "default": "search-agent-output/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "trace": {
      "$ref": "#/$defs/TraceReference"
    },
    "warnings": {
      "items": {
        "$ref": "#/$defs/PublicWarning"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "request_id",
    "document_id",
    "paragraph_id",
    "run_status",
    "results",
    "citations"
  ],
  "title": "SearchAgentOutputState",
  "type": "object"
}