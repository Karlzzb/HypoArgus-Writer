{
  "$defs": {
    "AtomicClaimDecision": {
      "additionalProperties": false,
      "properties": {
        "citation_ids": {
          "items": {
            "type": "string"
          },
          "title": "Citation Ids",
          "type": "array"
        },
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "claim_text": {
          "title": "Claim Text",
          "type": "string"
        },
        "logic_role": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Logic Role"
        },
        "missing_slots": {
          "items": {
            "type": "string"
          },
          "title": "Missing Slots",
          "type": "array"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "verdict": {
          "enum": [
            "SUPPORTED",
            "REFUTED",
            "CONFLICT",
            "INCONCLUSIVE"
          ],
          "title": "Verdict",
          "type": "string"
        }
      },
      "required": [
        "claim_id",
        "claim_text",
        "verdict",
        "reason"
      ],
      "title": "AtomicClaimDecision",
      "type": "object"
    },
    "EvidenceGap": {
      "additionalProperties": false,
      "properties": {
        "gap_retrieval_triggered": {
          "default": false,
          "title": "Gap Retrieval Triggered",
          "type": "boolean"
        },
        "missing_slots": {
          "items": {
            "type": "string"
          },
          "title": "Missing Slots",
          "type": "array"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "resolved": {
          "default": false,
          "title": "Resolved",
          "type": "boolean"
        }
      },
      "required": [
        "reason"
      ],
      "title": "EvidenceGap",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "atomic_claim_results": {
      "items": {
        "$ref": "#/$defs/AtomicClaimDecision"
      },
      "title": "Atomic Claim Results",
      "type": "array"
    },
    "citation_ids": {
      "items": {
        "type": "string"
      },
      "title": "Citation Ids",
      "type": "array"
    },
    "conclusion_summary": {
      "title": "Conclusion Summary",
      "type": "string"
    },
    "confidence": {
      "maximum": 1,
      "minimum": 0,
      "title": "Confidence",
      "type": "number"
    },
    "evidence_gap": {
      "anyOf": [
        {
          "$ref": "#/$defs/EvidenceGap"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "hypothesis_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Hypothesis Id"
    },
    "item_id": {
      "title": "Item Id",
      "type": "string"
    },
    "line_type": {
      "enum": [
        "forward",
        "reverse"
      ],
      "title": "Line Type",
      "type": "string"
    },
    "node_id": {
      "title": "Node Id",
      "type": "string"
    },
    "refuting_citation_ids": {
      "items": {
        "type": "string"
      },
      "title": "Refuting Citation Ids",
      "type": "array"
    },
    "run_status": {
      "enum": [
        "SUCCESS",
        "PARTIAL",
        "ERROR"
      ],
      "title": "Run Status",
      "type": "string"
    },
    "supplementary_citation_ids": {
      "items": {
        "type": "string"
      },
      "title": "Supplementary Citation Ids",
      "type": "array"
    },
    "supporting_citation_ids": {
      "items": {
        "type": "string"
      },
      "title": "Supporting Citation Ids",
      "type": "array"
    },
    "target_text": {
      "title": "Target Text",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "verdict": {
      "enum": [
        "SUPPORTED",
        "REFUTED",
        "CONFLICT",
        "INCONCLUSIVE"
      ],
      "title": "Verdict",
      "type": "string"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "task_id",
    "item_id",
    "node_id",
    "line_type",
    "target_text",
    "run_status",
    "verdict",
    "confidence",
    "conclusion_summary"
  ],
  "title": "TaskDecision",
  "type": "object"
}