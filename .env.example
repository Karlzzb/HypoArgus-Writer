# ── 全局缺省 LLM 配置（必填）────────────────────────────────
# 所有模型统一按 OpenAI 兼容接口封装，base_url 止于兼容根路径（不要带 /chat/completions）。
LLM_MODEL=qwen3.7-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-key

# ── 运行单元独立 LLM 配置（可选，逐字段回落全局缺省）──────────
# 8 个运行单元前缀：FRAMEWORK_ORCHESTRATOR / REFERENCE_ORCHESTRATOR / CHAPTER_DRAFTER /
# WRITING_ORCHESTRATOR / CITATION_VALIDATOR / HUMAN_REVIEW_GATE / SEARCH_AGENT / REWRITER_LOOP
# 每个前缀支持三个变量：<前缀>_LLM_MODEL / <前缀>_LLM_BASE_URL / <前缀>_LLM_API_KEY
# 分工：编排与校验换一代模型降低与写作模型的同源偏差；高频轻量任务用 flash。
REFERENCE_ORCHESTRATOR_LLM_MODEL=qwen3.6-plus
CITATION_VALIDATOR_LLM_MODEL=qwen3.6-plus
SEARCH_AGENT_LLM_MODEL=qwen3.6-flash
HUMAN_REVIEW_GATE_LLM_MODEL=qwen3.6-flash
# FRAMEWORK_ORCHESTRATOR_LLM_MODEL=
# FRAMEWORK_ORCHESTRATOR_LLM_BASE_URL=
# FRAMEWORK_ORCHESTRATOR_LLM_API_KEY=

# 思考模式缺省关闭（代码缺省即关，此处显式声明便于检索）：
# 结构化 JSON 任务上思考 token 达可见输出的 6 倍、延迟放大 5 倍（实测 50.8s → 9.3s）。
# 需要深度推理的单元用「单元名前缀 + LLM_ENABLE_THINKING=1」单独开启。
LLM_ENABLE_THINKING=0

# ── 状态持久化（必填）───────────────────────────────────────
# LangGraph Postgres 检查点保存器连接串。
HYPOARGUS_PG_DSN=postgresql://postgres:postgres@localhost:5432/postgres?sslmode=prefer

# 图级并行分支上限：首写阶段 Send 扇出的并发度（缺省 4，兼顾服务商限流）。
# GRAPH_MAX_CONCURRENCY=4

# 章节级 LLM 调用并发度：论证框架（论点假说）与引文语义核查。
FRAMEWORK_MAX_CONCURRENT_CHAPTERS=8
CITATION_MAX_CONCURRENT_CHAPTERS=8

# ── search_agent 检索通道 ───────────────────────────────────
# 检索引擎的 LLM 走上方统一规范（SEARCH_AGENT_LLM_* 回落全局 LLM_*），无独立凭据变量；
# 证据裁决可用 JUDGE_MODEL 单独覆盖模型（缺省用 search_agent 单元模型）。
# JUDGE_MODEL=
# 适配层外部调用总并发：并行章节检索分支共享的信号量阈值（缺省 2）。
# SEARCH_AGENT_MAX_CONCURRENT_CALLS=2
# 每章 pass 落库下限：强支撑素材低于此值即发薄弱章警告并计入诊断摘要
# （不阻断不补检、检索保持单轮；计数只数 pass、不数 inconclusive；缺省 3）。
# SEARCH_AGENT_MIN_PASS_PER_CHAPTER=3
# 引擎 LLM 能力开关（缺省开启）：结构化意图解析 / 证据裁决。
# SEARCH_AGENT_STRUCTURED_INTENT_LLM_ENABLED=1
# SEARCH_AGENT_EVIDENCE_JUDGE_LLM_ENABLED=1
# 影子模式（缺省开启）：跑完整检索与追踪，但禁止向外部系统传播与回写。
# SEARCH_AGENT_SHADOW_MODE=1
# 火山联网搜索：
# VOLCANO_SEARCH_BASE_URL=https://open.volcengineapi.com
# VOLCANO_SEARCH_PATH=/api/v1/search
# VOLCANO_SEARCH_API_KEY=
# Bisheng 知识库检索：
# BISHENG_BASE_URL=
# BISHENG_RETRIEVE_BASE_URL=
# BISHENG_TOKEN=
# 公共知识库 id 清单（逗号分隔）。
# PUBLIC_KNOWLEDGE_IDS=
# Doris 结构化查询（host / username / password 必须同时配置才启用）：
# DORIS_HOST=
# DORIS_PORT=9030
# DORIS_DATABASE=
# DORIS_USERNAME=
# DORIS_PASSWORD=
# 联网检索域名白名单（逗号分隔，配合 EVIDENCE_RETRIEVAL_WEB_WHITELIST_ENABLED）。
# WEB_ALLOWED_DOMAINS=
# 其余引擎细项（各通道超时、并发、重试、代理开关等）经通用前缀
# EVIDENCE_RETRIEVAL_<字段大写> 配置，字段清单见 src/search_agent/evidence_retrieval/config.py。
# EVIDENCE_RETRIEVAL_WEB_TRUSTED_PROXY_ENABLED=0

# ── 可观测（自建 Langfuse）──────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_BASE_URL=http://localhost:3000
# 大 generation 事件导出超时（秒）
LANGFUSE_TIMEOUT=600
# 总开关：设 false 关闭上报（公私钥可留着不动），非 false 即开
# LANGFUSE_TRACING_ENABLED=false

# ── 论证体系数量上限（可选，缺省 4 / 3 / 60）─────────────────
# 依次为：每章论点数上限 / 每论点假说数上限 / 全文假说总数上限。
# FRAMEWORK_MAX_POINTS_PER_CHAPTER=4
# FRAMEWORK_MAX_HYPOTHESES_PER_POINT=3
# FRAMEWORK_MAX_HYPOTHESES_TOTAL=60

# ── 引文终审（可选）─────────────────────────────────────────
# 终审失败定向回退重写的重试上限，超限携未决警告交人工裁决。
# CITATION_MAX_RETRIES=2

# ── 上下文装配压缩阈值（可选）───────────────────────────────
# 摘要链最大字符数 / 摘要压缩后字符数 / 修订台账保留最近轮数 / 台账早期轮次摘要字符数。
# ASSEMBLER_SUMMARY_CHAIN_MAX_CHARS=800
# ASSEMBLER_SUMMARY_DIGEST_MAX_CHARS=60
# ASSEMBLER_LEDGER_KEEP_ROUNDS=2
# ASSEMBLER_LEDGER_DIGEST_MAX_CHARS=60

# ── 调测（可选）─────────────────────────────────────────────
# 设为 1 打印逐次 LLM 调用计时。
# LLM_DEBUG_TIMING=1
