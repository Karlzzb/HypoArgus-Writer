# ── 全局缺省 LLM 配置（必填）────────────────────────────────
# 所有模型统一按 OpenAI 兼容接口封装，base_url 止于兼容根路径（不要带 /chat/completions）。
LLM_MODEL=qwen3.7-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-key

# ── 运行单元独立 LLM 配置（可选，逐字段回落全局缺省）──────────
# 7 个运行单元前缀：FRAMEWORK_ORCHESTRATOR / REFERENCE_ORCHESTRATOR / WRITING_ORCHESTRATOR /
# CITATION_VALIDATOR / HUMAN_REVIEW_GATE / SEARCH_AGENT / REWRITER_LOOP
# 每个前缀支持三个变量：<前缀>_LLM_MODEL / <前缀>_LLM_BASE_URL / <前缀>_LLM_API_KEY
# 分工：编排与校验换一代模型降低与写作模型的同源偏差；高频轻量任务用 flash。
REFERENCE_ORCHESTRATOR_LLM_MODEL=qwen3.6-plus
CITATION_VALIDATOR_LLM_MODEL=qwen3.6-plus
SEARCH_AGENT_LLM_MODEL=qwen3.6-flash
HUMAN_REVIEW_GATE_LLM_MODEL=qwen3.6-flash
# FRAMEWORK_ORCHESTRATOR_LLM_MODEL=
# FRAMEWORK_ORCHESTRATOR_LLM_BASE_URL=
# FRAMEWORK_ORCHESTRATOR_LLM_API_KEY=

# 思考模式缺省关闭（代码缺省即关，此处显式声明便于检索）：
# 结构化 JSON 任务上思考 token 达可见输出的 6 倍、延迟放大 5 倍（实测 50.8s → 9.3s）。
# 需要深度推理的单元用「单元名前缀 + LLM_ENABLE_THINKING=1」单独开启。
LLM_ENABLE_THINKING=0

# ── 状态持久化（必填）───────────────────────────────────────
# LangGraph Postgres 存档器连接串。
HYPOARGUS_PG_DSN=postgresql://postgres:postgres@localhost:5432/postgres?sslmode=prefer

# 章节级 LLM 调用并发度：论证框架（论点假说）与引文语义核查。
FRAMEWORK_MAX_CONCURRENT_CHAPTERS=8
CITATION_MAX_CONCURRENT_CHAPTERS=8

# ── 可观测（自建 Langfuse）──────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_BASE_URL=http://localhost:3000
# 大 generation 事件导出超时（秒）
LANGFUSE_TIMEOUT=600

# ── 论证体系数量上限（可选，缺省 4 / 3 / 60）─────────────────
# 依次为：每章论点数上限 / 每论点假说数上限 / 全文假说总数上限。
# FRAMEWORK_MAX_POINTS_PER_CHAPTER=4
# FRAMEWORK_MAX_HYPOTHESES_PER_POINT=3
# FRAMEWORK_MAX_HYPOTHESES_TOTAL=60
